{
  "name": "ganacr",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "seed": "tsx --tsconfig scripts/tsconfig.json scripts/seed.ts",
    "cleanup": "tsx --tsconfig scripts/tsconfig.json scripts/cleanup.ts",
    "copy-to-demo": "tsx --tsconfig scripts/tsconfig.json scripts/copy-to-demo.ts",
    "verify-demo": "tsx --tsconfig scripts/tsconfig.json scripts/verify-demo.ts",
    "clean-demo": "tsx --tsconfig scripts/tsconfig.json scripts/clean-demo-fields.ts",
    "wipe-demo": "tsx --tsconfig scripts/tsconfig.json scripts/wipe-demo.ts",
    "backup:export": "tsx --tsconfig scripts/tsconfig.json scripts/export-backup.ts",
    "backup:import": "tsx --tsconfig scripts/tsconfig.json scripts/import-backup.ts",
    "backup:verify": "tsx --tsconfig scripts/tsconfig.json scripts/verify-backup.ts",
    "emu": "firebase emulators:start --only firestore,auth --project ganacr",
    "seed:emulator": "tsx scripts/seed-emulator.ts",
    "test:e2e": "firebase emulators:exec --only firestore,auth --project ganacr \"playwright test\"",
    "test:rules": "firebase emulators:exec --only firestore --project ganacr \"node --import tsx --test tests/rules/firestore-rules.test.ts\"",
    "test:backup": "firebase emulators:exec --only firestore --project ganacr \"node --import tsx --test tests/backup/round-trip.test.ts\"",
    "test:unit": "node --import tsx --test \"tests/unit/**/*.test.ts\"",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.14",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/react": "^10.57.0",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.3.1",
    "firebase": "^10.8.0",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.3",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^14.27.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
