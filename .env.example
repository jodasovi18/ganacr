# ─── Credenciales de usuario de prueba para Playwright E2E ──────────────────
# Crear un usuario en Firebase Auth para las pruebas y poner sus datos aquí.
# Este archivo NO debe tener valores reales — es solo documentación.
# Copiar como .env y completar los valores.

# Email y contraseña del usuario de prueba en Firebase Auth
TEST_EMAIL=test-qa@tudominio.com
TEST_PASSWORD=contraseña-segura-de-prueba

# UID de Firebase Auth del usuario de prueba (ver Firebase Console → Authentication)
# Debe coincidir con el userId de los documentos sembrados por `npm run seed`
TEST_USER_ID=uid-del-usuario-en-firebase

# ─── Copia de datos reales al usuario demo ────────────────────────────────────
# UID del usuario real cuyos datos se copiarán al usuario demo.
# Usado por `npm run copy-to-demo` para crear demo@ganacr.com con datos reales.
SOURCE_USER_ID=uid-del-usuario-real

# ─── Monitoreo de errores (Sentry) ────────────────────────────────────────────
# DSN del proyecto en Sentry (sentry.io → proyecto → Settings → Client Keys (DSN)).
# Es una clave pública (va al bundle del navegador). Solo se activa en builds de
# producción. En producción se configura en las variables de entorno de Vercel.
VITE_SENTRY_DSN=
